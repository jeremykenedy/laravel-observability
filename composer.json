{
    "name": "jeremykenedy/laravel-observability",
    "description": "A Laravel package providing observability with auto-detection of Sentry, Bugsnag, Datadog, and Flare, plus APM metrics, health checks, and error context enrichment.",
    "keywords": ["laravel", "observability", "sentry", "bugsnag", "datadog", "flare", "apm", "health"],
    "license": "MIT",
    "type": "library",
    "authors": [{"name": "Jeremy Kenedy", "email": "jeremykenedy@gmail.com"}],
    "require": {
        "php": "^8.2|^8.3|^8.4",
        "illuminate/support": "^10.0|^11.0|^12.0|^13.0",
        "illuminate/routing": "^10.0|^11.0|^12.0|^13.0"
    },
    "require-dev": {
        "laravel/pint": "^1.29",
        "orchestra/testbench": "^8.0|^9.0|^10.0|^11.0",
        "pestphp/pest": "^2.0|^3.0|^4.0",
        "pestphp/pest-plugin-laravel": "^2.0|^3.0|^4.0"
    },
    "autoload": { "psr-4": { "Jeremykenedy\\LaravelObservability\\": "src/" } },
    "autoload-dev": { "psr-4": { "Jeremykenedy\\LaravelObservability\\Tests\\": "tests/" } },
    "extra": { "laravel": { "providers": ["Jeremykenedy\\LaravelObservability\\Providers\\ObservabilityServiceProvider"] } },
    "config": { "sort-packages": true, "allow-plugins": { "pestphp/pest-plugin": true } },
    "minimum-stability": "stable",
    "prefer-stable": true
}
